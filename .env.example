LOG_LEVEL=INFO
CORPUS_PATH=docs/laws
PLAYWRIGHT_TIMEOUT_SECONDS=60
USER_AGENT=LegalSiteScanner/0.1 (+https://github.com/freevad-pro/legal-site)

# Iteration 4: API, PDF
DATABASE_PATH=data/db.sqlite
SCAN_TIMEOUT_SECONDS=300
SCAN_STATE_TTL_SECONDS=3600

# Iteration 5a: cookie-сессии
SESSION_COOKIE_NAME=legal_site_session
SESSION_TTL_DAYS=30
# локально false; в проде на HTTPS — true
SESSION_COOKIE_SECURE=false

# Iteration 6: CORS-origins для dev-фронта (Next.js на :3000).
# В production оставлять пустым — фронт лежит на одном origin с API.
# Формат — JSON-массив (pydantic-settings парсит как list[str]).
CORS_DEV_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
